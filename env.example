# -----------------------------------------------
# Terra 2.0 — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# -----------------------------------------------

# --- Postgres ---
POSTGRES_USER=terra
POSTGRES_PASSWORD=changeme
POSTGRES_DB=terra_db

# Prisma connection string — must match the values above
# In compose, HOST is the service name: db
DATABASE_URL=postgresql://terra:changeme@db:5432/terra_db

# --- App ---
APP_URL=http://localhost:3000

# --- Auth ---
JWT_SECRET=generate-with-openssl-rand-base64-32

# --- Twilio (SMS 2FA) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Docker Image (prod only) ---
IMAGE_NAME=your-registry/terra-app
IMAGE_TAG=latest

# --- pgAdmin (dev only) ---
PGADMIN_EMAIL=admin@terra.local
PGADMIN_PASSWORD=changeme
